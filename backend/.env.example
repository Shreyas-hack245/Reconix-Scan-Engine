# Reconix Scan Engine - Environment Configuration Example
# Copy this file to `.env` and adjust values for your environment.

APP_NAME="Reconix Scan Engine"
ENVIRONMENT=development
DEBUG=true

# Security / JWT
SECRET_KEY=change-this-to-a-long-random-secret-value
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Database
DATABASE_URL=sqlite+aiosqlite:///./reconix.db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting / crawling safety
DEFAULT_REQUEST_TIMEOUT_SECONDS=10
DEFAULT_MAX_CONCURRENT_REQUESTS=5
DEFAULT_REQUESTS_PER_SECOND=5
DEFAULT_MAX_CRAWL_DEPTH=3
DEFAULT_MAX_PAGES_PER_SCAN=200

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./logs/audit.log